# Orgistry environment configuration.
#
# Copy to `.env` and adjust as needed: `cp .env.example .env`.
# Every variable below maps to the Zod schema in packages/config/src/schema.ts.
# Values here are LOCAL DEVELOPMENT DEFAULTS — never commit real secrets.

# ----- Runtime -----
# development | test | production
NODE_ENV=development
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ----- API HTTP server -----
API_HOST=0.0.0.0
API_PORT=3000

# ----- Web demo -----
WEB_DEMO_URL=http://localhost:5173

# ----- CORS (comma-separated allow-list) -----
CORS_ORIGINS=http://localhost:5173

# ----- PostgreSQL (durable local store) -----
# Must match the docker compose credentials below.
DATABASE_URL=postgres://orgistry:orgistry@localhost:5432/orgistry
# Separate database used by the test suites / `pnpm db:reset:test`.
TEST_DATABASE_URL=postgres://orgistry:orgistry@localhost:5432/orgistry_test

# Consumed only by infra/docker-compose.yml (Postgres container provisioning).
POSTGRES_USER=orgistry
POSTGRES_PASSWORD=orgistry
POSTGRES_DB=orgistry

# ----- Redis (future rate limiting + readiness probe) -----
REDIS_URL=redis://localhost:6379

# ----- Mailpit (future local email flows) -----
MAILPIT_HOST=localhost
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ----- Auth secrets -----
# Minimum 16 characters. Replace with strong values per environment.
JWT_SECRET=dev-only-jwt-secret-change-me
COOKIE_SECRET=dev-only-cookie-secret-change-me
# false on localhost over HTTP; true in production-like (HTTPS) environments.
# Drives the refresh cookie's `Secure` attribute.
COOKIE_SECURE=false
# Access token lifetime in seconds (short-lived). Default: 15 minutes.
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
# Session lifetime in seconds (outlives any single access token). Default: 30 days.
AUTH_SESSION_TTL_SECONDS=2592000
# Refresh token lifetime in seconds; also the refresh cookie Max-Age. Default: 30 days.
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# ----- Refresh cookie + CSRF -----
# Refresh cookie name and path scope. The cookie is always HttpOnly + SameSite=Lax.
AUTH_REFRESH_COOKIE_NAME=orgistry_rt
AUTH_REFRESH_COOKIE_PATH=/v1/auth
# Custom header required on cookie-backed mutations (refresh/logout). Case-insensitive.
AUTH_CSRF_HEADER_NAME=x-orgistry-csrf

# ----- Generic rate limit namespace (not used by the auth buckets below) -----
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=100

# ----- Auth rate-limit buckets (Redis-backed; fixed-window, one shared length) -----
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_PER_IP_MAX=10
RATE_LIMIT_LOGIN_PER_EMAIL_MAX=5
RATE_LIMIT_REGISTER_PER_IP_MAX=5
RATE_LIMIT_REFRESH_PER_SESSION_MAX=60
RATE_LIMIT_REFRESH_PER_IP_MAX=120
